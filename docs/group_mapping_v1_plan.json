{
  "title": "FG/BG Murmur Group Mapping UI v1",
  "summary": "Global Cube-group to Murmur-group mapping with per-server Murmur inventory, BG-side buffered ICE snapshots, FG-owned mapping and ignore state, and shared server-label behavior with /profile/.",
  "inventory": {
    "bg_merge_behavior": "none",
    "bg_buffered_cache": true,
    "freshness_default_seconds": 600,
    "freshness_configurable": true
  },
  "fg_state": [
    "cube_group_ignore_state",
    "murmur_group_ignore_state_global_by_name",
    "cube_group_to_murmur_group_mapping",
    "per_server_inventory_snapshot"
  ],
  "permissions": {
    "global_only": true,
    "codenames": [
      "view_group_mapping",
      "change_group_mapping",
      "add_group_mapping",
      "delete_group_mapping"
    ],
    "admin_bypass": "is_mumble_admin on any eligible Murmur account"
  },
  "ui": {
    "server_control": {
      "multiple": "selector",
      "single": "fixed_text",
      "zero": "unavailable"
    },
    "mapping_rendering": {
      "suppressed": "grey_with_reason"
    },
    "actions": [
      "refresh_selected_server",
      "import_from_selected_server",
      "export_selected_server_to_all",
      "overwrite_all_from_selected_server",
      "cleanup_ignored_mappings"
    ]
  }
}
